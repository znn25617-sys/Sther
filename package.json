{
  "name": "aetherias-ascent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Aetheria's Ascent — a magical 2D side-scroller coin & treasure collecting game.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite build && electron electron/main.cjs",
    "electron:build": "vite build && electron-builder",
    "cap:sync": "cap sync"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "pixi.js": "^7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.20.5"
  },
  "build": {
    "appId": "com.aetheria.ascent",
    "productName": "Aetherias Ascent",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "electron/build"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "AetheriasAscent-Portable.exe"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
